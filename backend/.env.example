# ============================================
# Application Settings
# ============================================
APP_NAME=ContractSentinel
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ============================================
# Database Settings
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contract_sentinel

# ============================================
# Redis Settings
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT Settings
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============================================
# Encryption and Data Retention
# ============================================
# Optional; omit to derive from JWT_SECRET. Use KMS/Secret in production.
ENCRYPTION_KEY=
ENCRYPTION_ENABLED=true
KEY_ROTATION_DAYS=90
DATA_RETENTION_DAYS=365

# ============================================
# File Storage Settings
# ============================================
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50

# ============================================
# LLM Provider Settings
# ============================================
# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI Compatible (for local models like Ollama, vLLM)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1

# SiliconFlow
SILICONFLOW_API_KEY=

# ============================================
# Default Provider Settings
# ============================================
DEFAULT_CHAT_PROVIDER=deepseek
DEFAULT_CHAT_MODEL=deepseek-chat
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# Web-RAG Settings
# ============================================
RAG_CRAWL_RATE_LIMIT=1.0
RAG_CACHE_TTL_HOURS=24
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
