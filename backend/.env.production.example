# ========== 生产环境配置 ==========

# 必须修改
JWT_SECRET=这里改成复杂的随机字符串，至少32位
DEBUG=False
APP_ENV=production
ENCRYPTION_KEY=这里改成复杂的随机字符串

# 数据库（Railway会自动注入，无需手动修改）
# DATABASE_URL=postgresql://...

# Redis（Railway会自动注入，无需手动修改）
# REDIS_URL=redis://...

# CORS（改成你的域名，多个用逗号分隔）
CORS_ORIGINS=https://你的域名.com

# LLM（填入你的API Key）
OPENAI_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx

# 默认模型配置
DEFAULT_CHAT_PROVIDER=deepseek
DEFAULT_CHAT_MODEL=deepseek-reasoner
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# 文件上传限制
MAX_FILE_SIZE_MB=50
